# Kopiere diese Datei zu .env.local und trage deine Werte ein.
# .env.local ist in .gitignore und wird NIE committed.

# Supabase — aus Projekt-Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key — NIEMALS im Client verwenden.
# Nur in Server Components, Route Handlers und Server Actions.
SUPABASE_SERVICE_ROLE_KEY=

# --- KI-Dienste (PFLICHT für Produktion) ---
# Anthropic Claude — Gliederung, Kapitel, Recherche, Lektorat, KDP-Listing
ANTHROPIC_API_KEY=
# Optional: Modell-ID überschreiben (Default im Code: claude-sonnet-4-6).
# Vor Go-Live gegen das Anthropic-Konto verifizieren!
# ANTHROPIC_MODEL=
# Replicate — Cover-Generierung (Flux)
REPLICATE_API_TOKEN=

# --- Stripe (PFLICHT für Bezahlung) ---
# Live-Keys aus dem Stripe-Dashboard; Preis-IDs für Buch (19,99 €) und Abo (29,99 €/Mon.)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BOOK=
STRIPE_PRICE_SUB=

# --- E-Mail (PFLICHT: DOI-/Kaufbestätigung, §356 BGB) ---
# Resend-API-Key; Domain buchwerk.info muss in Resend verifiziert sein
RESEND_API_KEY=

# --- Monitoring ---
# Sentry DSN (Client+Server). SENTRY_AUTH_TOKEN nur im Build für Source-Maps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Preview-Gate / Go-Live ---
# SITE_LIVE=true schaltet die Seite öffentlich (sonst leitet alles auf /bald).
SITE_LIVE=
# Token für Vorschau-Bypass: /?preview=<token> setzt ein Cookie.
SITE_BYPASS_TOKEN=
# Kanonische Domain für Metadaten/Sitemap/Robots (Default: https://buchwerk.info)
# NEXT_PUBLIC_SITE_URL=https://buchwerk.info
# Analytics (optional, DSGVO-freundlich, ohne Cookie): Plausible-Domain setzen,
# um Tracking zu aktivieren. Leer = kein Analytics-Script.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=buchwerk.info

# Admin-Bereich — kommagetrennte Allowlist der Admin-Mails
ADMIN_EMAILS=

# Google-Login nur anzeigen, wenn der Google-Provider in Supabase Auth
# eingerichtet ist. Sonst bleibt der Button ausgeblendet (E-Mail/Passwort geht).
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=

# Buchshop: Amazon-Partner-Tag für die Affiliate-Links (optional)
AMAZON_PARTNER_TAG=

# Posteingang: IMAP-Abruf der welcome@-Mailbox (All-inkl)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=welcome@buchwerk.info
IMAP_PASSWORD=

# Schützt den Cron-Endpunkt /api/inbound/poll (Vercel Cron sendet ihn als Bearer-Token)
CRON_SECRET=
