# Kopiere diese Datei zu .env.local und trage deine Werte ein.
# .env.local ist in .gitignore und wird NIE committed.

# Supabase — aus Projekt-Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key — NIEMALS im Client verwenden.
# Nur in Server Components, Route Handlers und Server Actions.
SUPABASE_SERVICE_ROLE_KEY=
